PORT=8787

# Set to 1 / true / yes for a small private deployment: no rate limit, permissive CORS, optional Bearer,
# any http(s) target host (still blocks file: and credentials-in-URL). Not for public internet.
PDF_RELAX_SECURITY=

# CRA / frontend origin allowed to call this API (production). Example: https://your-app.vercel.app
ALLOWED_APP_ORIGIN=
# Shared secret for manual testing (min 32 chars recommended)
PDF_API_SECRET=

# Supabase JWT secret (Settings → API → JWT Secret) — preferred for CRA + logged-in users
SUPABASE_JWT_SECRET=

# Production: required. URLs passed to export must start with this prefix (e.g. https://your-app.vercel.app)
ALLOWED_PDF_ORIGIN=

# Optional: system Chromium when using puppeteer-core
PUPPETEER_EXECUTABLE_PATH=
